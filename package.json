{
  "name": "askdatdude.github.io",
  "version": "3.0.0",
  "description": "Robin Niinemets portfolio: work, writing, and tools.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "validate:assets": "bun run scripts/validate-assets.ts",
    "test": "bun test --preload ./tests/setup.ts tests/unit tests/components",
    "test:unit": "bun test --preload ./tests/setup.ts tests/unit",
    "test:components": "bun test --preload ./tests/setup.ts tests/components",
    "test:coverage": "bun test --coverage --preload ./tests/setup.ts tests/unit tests/components",
    "test:all": "bun run test && bun run validate:assets && bun run build"
  },
  "keywords": [
    "portfolio",
    "cybersecurity",
    "student",
    "work"
  ],
  "author": "Robin Niinemets",
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "preact": "^10.29.2",
    "preact-iso": "^2.12.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^29.1.1",
    "vite": "^8.0.14"
  }
}
